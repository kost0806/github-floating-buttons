{
  "manifest_version": 3,
  "name": "GitHub Floating Buttons",
  "version": "0.0.3",
  "description": "GitHub / GitHub Enterprise 페이지 우측 하단에 유용한 floating 버튼을 추가합니다 (PR 목록, 맨 위로 스크롤, 리뷰창 열기/자동 approve).",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://github.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "src/common/constants.js",
        "src/content/content.js"
      ],
      "css": [
        "src/content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/options.html",
  "action": {
    "default_title": "GitHub Floating Buttons 설정"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
